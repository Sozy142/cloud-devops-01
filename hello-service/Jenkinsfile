pipeline {
    agent { label 'linux-docker' }

    stages {
        stage('Checkout') {
            steps {
                echo 'Code checked out automatically by Jenkins'
            }
        }

        stage('Build') {
            steps {
                sh 'docker build -t hello-service:${BUILD_NUMBER} hello-service/'
            }
        }

        stage('Test') {
            steps {
                sh '''
                    docker ps -q --filter "publish=3000" | xargs -r docker stop
                    docker ps -aq --filter "publish=3000" | xargs -r docker rm
                    docker run -d --name app-test-${BUILD_NUMBER} -p 3000:3000 hello-service:${BUILD_NUMBER}
                    sleep 5
                    curl -f http://localhost:3000/health
                    curl -f http://localhost:3000/version
                    curl -f http://localhost:3000/
                    docker stop app-test-${BUILD_NUMBER}
                    docker rm app-test-${BUILD_NUMBER}
                '''
            }
        }
    }

    post {
        always {
            sh '''
                docker stop app-test-${BUILD_NUMBER} || true
                docker rm app-test-${BUILD_NUMBER} || true
                docker rmi hello-service:${BUILD_NUMBER} || true
            '''
        }
    }
}